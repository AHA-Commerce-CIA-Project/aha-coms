# apps/fast environment template
#
# Production secrets live in Google Secret Manager and are projected into the
# Cloud Run service via infra/fast/cloud-run.tf. Local development pulls from
# `.env.local` (gitignored). This file documents what each variable carries so
# new operators can shape their own local environment without spelunking through
# `process.env.*` references.
#
# Post-Phase-4 (T65), the app mounts at `/fast/` of the shared Firebase Hosting
# origin (`aha-coms.web.app`). Every absolute URL below already reflects the
# basePath; older `.env.local` files that pre-date Phase 4 must be updated to
# match before a local run can talk to portal-api or accept an OAuth callback.

# === App origin ===
NEXT_PUBLIC_APP_URL=https://aha-coms.web.app
NEXT_PUBLIC_PORTAL_ORIGIN=https://aha-coms.web.app
PORTAL_ORIGIN=https://aha-coms.web.app

# === Database ===
# Prisma DSN — points at fast's own Cloud SQL instance via the Auth Proxy in
# local dev, or at the Unix socket in Cloud Run.
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/aha_fast?schema=public

# === Google OAuth (Calendar + Chat read scopes) ===
# The redirect URI MUST be registered in Google Cloud Console under the OAuth
# 2.0 client's authorized redirect URIs list. Post-T65, the callback path is
# `/fast/api/auth/google/callback` (was `/api/auth/google/callback` pre-Phase-4).
# T67 registers the new URI; keep the old URI registered through one rollback
# window so a Phase 4 revert can still complete OAuth flows on the prior path.
GOOGLE_CLIENT_ID=YOUR-OAUTH-CLIENT-ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR-OAUTH-CLIENT-SECRET
GOOGLE_REDIRECT_URI=https://aha-coms.web.app/fast/api/auth/google/callback
GOOGLE_API_KEY=YOUR-GOOGLE-API-KEY

# === Google Sheets HR pull ===
HR_SPREADSHEET_ID=YOUR-HR-SHEET-ID
HR_SHEET_NAME=Employees

# === Apps Script email gateway ===
APPS_SCRIPT_EMAIL_URL=https://script.google.com/macros/s/DEPLOYMENT-ID/exec
APPS_SCRIPT_SECRET=YOUR-SHARED-HMAC

# === Notification admin address ===
# Reply-To / fallback recipient for outgoing mail through the Apps Script
# gateway. Read by apps/fast/lib/email.ts as NOTIFICATION_EMAIL.
ADMIN_NOTIFICATION_EMAIL=ops@example.com

# === Slack webhook (task escalations) ===
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T0/B0/SECRET

# === Cloud Storage ===
GCS_BUCKET_NAME=aha-fast-uploads-prod

# === Cron auth ===
CRON_SECRET=YOUR-SHARED-SECRET

# === Portal webhook verification (Spec 05 Phase 7 / T77) ===
# Inbound webhooks at POST /fast/api/webhooks/portal are verified by
# minting a Google ID token check against PORTAL_SERVICE_ACCOUNT_EMAIL
# with audience SELF_PUBLIC_URL. The audience portal mints is
# `new URL(endpoint.url).origin` — for single-origin fast that's the
# bare Firebase Hosting host with no `/fast` suffix. See FU-24 in
# tasks/todo.md + the verifier at apps/fast/lib/portal/oidc.ts.
PORTAL_SERVICE_ACCOUNT_EMAIL=coms-portal-run-sa@fbi-dev-484410.iam.gserviceaccount.com
SELF_PUBLIC_URL=https://aha-coms.web.app

# === Portal API base URL (Spec 05 Phase 7 / T78) ===
# Used by apps/fast/scripts/sync-taxonomies.ts when minting an ID token
# for portal-api's /api/taxonomies/sync endpoint. Required when running
# the one-shot initial sync; ignored by the running container at runtime.
PORTAL_BASE_URL=https://aha-coms.web.app
