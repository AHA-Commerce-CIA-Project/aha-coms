{
  "name": "@coms-portal/heroes-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./auth": "./src/auth.ts",
    "./services/*": "./src/services/*.ts",
    "./repositories/*": "./src/repositories/*.ts"
  },
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "bun --env-file=.env ../../packages/heroes-shared/src/db/seed/index.ts"
  },
  "dependencies": {
    "@coms-portal/heroes-shared": "workspace:*",
    "@coms-portal/heroes-web": "workspace:*",
    "@coms-portal/sdk": "workspace:*",
    "@elysiajs/cors": "^1.3.0",
    "@elysiajs/static": "^1.3.0",
    "@elysiajs/eden": "^1.3.0",
    "@sinclair/typebox": "^0.34.0",
    "drizzle-orm": "^0.45.0",
    "elysia": "^1.3.0",
    "postgres": "^3.4.5",
    "@google-cloud/storage": "^7.19.0",
    "@googleapis/sheets": "^13.0.1",
    "google-auth-library": "^9.15.1"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31",
    "typescript": "^6.0.0"
  }
}
