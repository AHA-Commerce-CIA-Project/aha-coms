{
  "name": "@coms-portal/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./src/db/schema/identity-users": "./src/db/schema/identity-users.ts",
    "./src/db/schema/teams": "./src/db/schema/teams.ts",
    "./src/db/schema/apps": "./src/db/schema/apps.ts",
    "./src/*": "./src/*"
  },
  "scripts": {
    "dev": "bun --watch server.ts",
    "build": "bun build server.ts --outdir dist --target bun",
    "start": "bun server.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@coms-portal/shared": "git+https://github.com/mrdoorba/coms-shared.git#v1.4.0",
    "@elysiajs/static": "^1.2",
    "@googleapis/sheets": "^13.0.1",
    "drizzle-orm": "^0.45.0",
    "elysia": "^1.3",
    "google-auth-library": "^10.6.2",
    "jose": "^6",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "^0.31",
    "typescript": "^5.8"
  }
}
