{
  "name": "@coms-portal/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./middleware/auth": "./src/middleware/auth.ts",
    "./services/auth": "./src/services/auth.ts",
    "./src/db/schema/identity-users": "./src/db/schema/identity-users.ts",
    "./src/db/schema/teams": "./src/db/schema/teams.ts",
    "./src/db/schema/apps": "./src/db/schema/apps.ts"
  },
  "scripts": {
    "dev": "bun --watch server.ts",
    "build": "bun build server.ts --outdir dist --target bun",
    "start": "bun server.ts",
    "typecheck": "tsc --noEmit",
    "test": "find src -name '*.test.ts' | sort | xargs -I{} -n1 -P 4 bun test {}",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed-admin": "bun scripts/seed-admin.ts",
    "db:studio": "drizzle-kit studio",
    "spec07:register-fast": "bun scripts/spec07-register-fast.ts",
    "spec07:provision-fast-orphans": "bun scripts/spec07-provision-fast-orphans.ts",
    "register:heroes": "bun scripts/register-heroes.ts",
    "bootstrap:heroes-membership": "bun scripts/bootstrap-heroes-membership.ts"
  },
  "dependencies": {
    "@coms-portal/sdk": "workspace:*",
    "@coms-portal/shared": "workspace:*",
    "@elysiajs/cors": "^1.4.2",
    "@elysiajs/static": "^1.2",
    "@elysiajs/swagger": "^1.3.1",
    "@getbrevo/brevo": "^3.0.1",
    "@googleapis/sheets": "^13.0.1",
    "drizzle-orm": "^0.45.0",
    "elysia": "^1.3",
    "google-auth-library": "^10.6.2",
    "jose": "^6",
    "pino": "^10.3.1",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "^0.31",
    "pino-pretty": "^13.1.3",
    "typescript": "^5.8"
  }
}
