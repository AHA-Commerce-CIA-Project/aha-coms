{
  "name": "coms-portal",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/ui-react/examples/smoketest"
  ],
  "scripts": {
    "dev": "bun run --filter '*' --parallel dev",
    "dev:portal-api": "bun run --filter @coms-portal/portal-api dev",
    "dev:portal-web": "bun run --filter @coms-portal/portal-web dev",
    "dev:heroes-api": "bun run --filter @coms-portal/heroes-api dev",
    "dev:heroes-web": "bash scripts/dev-heroes-web.sh",
    "build": "bun run --filter '@coms-portal/portal-*' build && bun run --filter '@coms-portal/heroes-*' build",
    "typecheck": "bun run --filter '*' typecheck",
    "test": "bun run --filter @coms-portal/portal-api test",
    "db:generate": "bun run --filter @coms-portal/portal-api db:generate",
    "db:migrate": "bun run --filter @coms-portal/portal-api db:migrate",
    "db:studio": "bun run --filter @coms-portal/portal-api db:studio",
    "test:e2e": "playwright test --config tests/playwright.config.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.50"
  }
}
