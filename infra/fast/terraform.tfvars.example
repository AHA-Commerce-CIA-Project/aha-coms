# infra/fast/terraform.tfvars.example
#
# Copy to terraform.tfvars and adjust for your environment. terraform.tfvars
# is gitignored (see ../../.gitignore's `infra/**/*.tfvars` rule); this
# .example file is committed as the schema reference.
#
# Two variables are required (no defaults). Other variables in variables.tf
# carry defaults targeting the fbi-dev-484410 project and the existing
# aha-fast-db-instance-* Cloud SQL host; override them via tfvars if
# deploying to a different environment.

# Where monitoring alert emails land. One operations inbox for the suite.
alert_email = "handers.the@ahacommerce.net"

# Bearer token /fast/api/cron/routine-scheduler verifies on inbound calls.
# Generate a fresh value via `openssl rand -base64 32` for new environments;
# preserve the existing prod value when bringing up coms-fast-web alongside
# the legacy aha-fast-app (Cloud Scheduler — when wired — must carry the
# same value in its outbound Authorization header). The validation in
# variables.tf rejects values shorter than 16 chars.
#
# Pull the legacy aha-fast-app value with:
#   gcloud run services describe aha-fast-app \
#     --region=asia-southeast2 --project=fbi-dev-484410 --format=json | \
#     python3 -c "import json,sys; \
#       e={v['name']:v.get('value') for v in json.load(sys.stdin)['spec']['template']['spec']['containers'][0]['env']}; \
#       print(e['CRON_SECRET'])"
cron_secret = "REPLACE_ME"
