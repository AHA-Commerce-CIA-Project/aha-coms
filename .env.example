# Database (Cloud SQL via Unix socket on Cloud Run)
DATABASE_URL=postgresql://app:***@/coms_system?host=/cloudsql/fbi-dev-484410:asia-southeast2:***

# Google Identity Platform
GIP_PROJECT_ID=fbi-dev-484410
GIP_API_KEY=***
GIP_AUTH_DOMAIN=fbi-dev-484410.firebaseapp.com

# Firebase Admin (server-side)
# On Cloud Run, leave unset — default service account is used automatically.
# For local dev, set to path of a service account JSON key file.
GOOGLE_APPLICATION_CREDENTIALS=

# App Config
COMS_DOMAIN=coms.ahacommerce.net
SESSION_COOKIE_MAX_AGE=1209600

# App Registry — path prefixes matching GCP LB routing rules
APP_HEROES_PATH=/heroes
APP_FAST_PATH=/fast
