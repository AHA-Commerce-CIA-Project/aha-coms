# Database (Cloud SQL via Unix socket on Cloud Run)
DATABASE_URL=postgresql://app:***@/coms_system?host=/cloudsql/fbi-dev-484410:asia-southeast2:***

# Google Identity Platform (client-side — VITE_ prefix required for Vite)
VITE_GIP_PROJECT_ID=fbi-dev-484410
VITE_GIP_API_KEY=***
VITE_GIP_AUTH_DOMAIN=fbi-dev-484410.firebaseapp.com

# Google Identity Platform (server-side — used by Firebase Admin SDK in
# apps/api/src/gip-admin.ts for setCustomUserClaims, createSessionCookie, etc.)
GIP_PROJECT_ID=fbi-dev-484410

# Firebase Admin (server-side)
# On Cloud Run, leave unset — default service account is used automatically.
# For local dev, set to path of a service account JSON key file.
GOOGLE_APPLICATION_CREDENTIALS=

# App Config
# Portal origin — the authoritative base URL for broker tokens, JWKS, and web-side links
# Used by: auth-broker.ts, well-known.ts, auth.ts, web admin/apps page
# Fallback (if unset): 'https://coms.ahacommerce.net'
PORTAL_PUBLIC_ORIGIN=

# Web origin — the web app's URL, used for CORS allowlist
WEB_ORIGIN=

# CORS allowed origins — comma-separated list of origins that may fetch the API
# In production, must be explicitly set (no default). In dev, localhost:* is auto-allowed.
CORS_ALLOWED_ORIGINS=

# Session cookie domain — the domain attribute set on the portal's session cookie
# Undefined in development (defaults to current host). Set in production if needed.
SESSION_COOKIE_DOMAIN=

SESSION_COOKIE_MAX_AGE=1209600

# App Registry — path prefixes matching GCP LB routing rules
APP_HEROES_PATH=/heroes
APP_FAST_PATH=/fast

# Personal Email Sync (Google Sheets)
SHEETS_PERSONAL_EMAIL_ID=1RS798qnTYwk8usogqjBaeYUTKQJMsONm4p1Cik92HYM
SHEETS_PERSONAL_EMAIL_TAB=HEROES - Fulltime Staff

# Session Introspection (machine-to-machine, relying-party apps only)
# Generate with: openssl rand -hex 32
# Must match PORTAL_INTROSPECT_SECRET set in each relying-party app's environment.
PORTAL_INTROSPECT_SECRET=

# Bootstrap admin: ensures an admin row exists after migrations. Idempotent.
# Run via `bun run db:seed-admin`. Wired as deploy post-migrate hook.
BOOTSTRAP_ADMIN_EMAIL=handers.the@ahacommerce.net
BOOTSTRAP_ADMIN_NAME=Mr. Door
# BOOTSTRAP_ADMIN_PERSONAL_EMAIL=optional@gmail.com
