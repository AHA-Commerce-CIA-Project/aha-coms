.claude/


# Type cache
*.tsbuildinfo

# OpenTofu / Terraform
infra/.terraform/
infra/*.tfstate
infra/*.tfstate.backup
infra/*.tfvars
!infra/*.tfvars.example
# infra/terraform.tfvars holds non-secret config (project ID, region, public
# domain, github repo, public sheet ID). Real secrets live in Secret Manager
# and are not referenced from tfvars. Tracked so CI can run `tofu apply`
# without re-injecting these values from repo vars.
!infra/terraform.tfvars
infra/tfplan
# Nested terraform trees (e.g. infra/heroes/) inherit the same rules.
infra/**/tfplan
infra/**/.terraform/
infra/**/*.tfstate
infra/**/*.tfstate.backup
infra/**/*.tfvars
!infra/**/*.tfvars.example
# infra/heroes/terraform.tfvars holds the Google Sheet IDs (per FU-9 ops
# decision 2026-05-13: not secret enough to warrant Secret Manager,
# environment-specific enough that variables.tf defaults can't carry them).
# Tracked so `tofu apply` works without operator-passed vars.
!infra/heroes/terraform.tfvars

# Service account keys — never commit, regardless of location
*.sa-key.json
# Note: infra/.terraform.lock.hcl IS tracked. CI runs
# `tofu init -lockfile=readonly` against it for reproducible providers.

# Personal folders
my-document/

# Dev scripts (local-only) — anchored to repo root.
# `apps/*/scripts/` are tracked. The top-level scripts/ folder is local-only
# except for explicit wrappers that belong in the repo (dev-* and verify-*).
# Glob the children rather than the directory so `!` re-inclusion works.
/scripts/*
!/scripts/dev-*.sh
!/scripts/verify-*.mjs

# SvelteKit build output
apps/portal-web/build/
apps/heroes-web/build/

# Firebase Hosting deploy cache (local-only, regenerated per deploy).
.firebase/
AGENTS.md
.mcp.json
.omx/
.omc/
.codex/
docs-secret/
.nelson/
my-design-guideline/
.playwright
