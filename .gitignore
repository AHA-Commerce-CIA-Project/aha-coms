# OpenTofu / Terraform
infra/.terraform/
infra/*.tfstate
infra/*.tfstate.backup
infra/*.tfvars
!infra/*.tfvars.example
# infra/terraform.tfvars holds non-secret config (project ID, region, public
# domain, github repo, public sheet ID). Real secrets live in Secret Manager
# and are not referenced from tfvars. Tracked so CI can run `tofu apply`
# without re-injecting these values from repo vars.
!infra/terraform.tfvars
infra/tfplan
# Nested terraform trees (e.g. infra/heroes/) inherit the same rules.
infra/**/.terraform/
infra/**/*.tfstate
infra/**/*.tfstate.backup
infra/**/*.tfvars
!infra/**/*.tfvars.example

# Service account keys — never commit, regardless of location
*.sa-key.json
# Note: infra/.terraform.lock.hcl IS tracked. CI runs
# `tofu init -lockfile=readonly` against it for reproducible providers.

# Personal folders
my-document/

# Dev scripts (local-only) — anchored to repo root.
# `apps/*/scripts/` are tracked; only the top-level scripts/ folder is local-only.
/scripts/

# SvelteKit build output
apps/web/build/
AGENTS.md
.mcp.json
.omx/
.omc/
.codex/
docs-secret/
.nelson/
