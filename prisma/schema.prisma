// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// BETTER AUTH REQUIRED MODELS
// ==========================================

model User {
  id            String   @id
  name          String
  email         String   @unique
  emailVerified Boolean
  image         String?
  createdAt     DateTime
  updatedAt     DateTime

  // Custom AHA Smart Tracker Fields
  role                String    @default("member") // 'leader' or 'member'
  status              String    @default("active") @db.VarChar(20) // 'active', 'away', 'busy', 'offline'
  lastSeenAt          DateTime? @map("last_seen_at") @db.Timestamptz(6)
  activeSecondsToday  Int       @default(0) @map("active_seconds_today")
  activeDate          DateTime? @map("active_date") @db.Date
  totalActiveSeconds  Int       @default(0) @map("total_active_seconds")
  lastChangelogSeenAt DateTime? @map("last_changelog_seen_at") @db.Timestamptz(6)
  accountStatus       String    @default("active") @map("account_status") @db.VarChar(30) // 'pending_activation', 'pending_setup', 'pending_approval', 'active', 'rejected'
  teamId              String?
  team                Team?     @relation(fields: [teamId], references: [id], onDelete: SetNull)

  // Relations
  sessions         Session[]
  accounts         Account[]
  tasks            Task[]         @relation("AssigneeTasks")
  completedTasks   Task[]         @relation("CompletedByTasks")
  notifications    Notification[]
  createdMeetings  Meeting[]      @relation("MeetingCreator")
  assignedMeetings Meeting[]      @relation("MeetingAssignee")
  meetingGuests    MeetingGuest[]
  googleToken      GoogleToken?

  // Chat / DM Relations
  conversationParticipants ConversationParticipant[]
  sentMessages             DirectMessage[]
  dmReactions              DmReaction[]

  // Channel Relations
  createdChannels     Channel[]           @relation("ChannelCreator")
  channelMemberships  ChannelMember[]
  channelMessages     ChannelMessage[]    @relation("ChannelMessageSender")
  threadReplies       ThreadReply[]       @relation("ThreadReplySender")
  messageReactions    MessageReaction[]
  savedMessages       SavedMessage[]
  savedTasks          SavedTask[]
  helperFor           TaskCollaborator[]  @relation("TaskHelpers")
  channelReadStatuses ChannelReadStatus[]

  // AHA ORBIT Relations
  routineTemplates RoutineTaskTemplate[]   @relation("RoutineTemplateCreator")
  routineClaims    RoutineTaskClaim[]      @relation("RoutineClaimUser")
  delegationsFrom  RoutineTaskDelegation[] @relation("DelegationFrom")
  delegationsTo    RoutineTaskDelegation[] @relation("DelegationTo")
  activityLogs     ActivityLog[]
  taskComments     TaskComment[]

  // Notes
  notes Note[] @relation("UserNotes")

  // Direct Request Relations
  directAssigneeTasks Task[]           @relation("DirectAssigneeTasks")
  taskDelegationsFrom TaskDelegation[] @relation("TaskDelegationFrom")
  taskDelegationsTo   TaskDelegation[] @relation("TaskDelegationTo")

  // Milestones
  milestonesCreated Milestone[] @relation("MilestonesCreated")
  milestonesClaimed Milestone[] @relation("MilestonesClaimed")

  // Daily activity snapshots (for week/month active hours analytics)
  activityDailies UserActivityDaily[] @relation("UserActivityDailies")

  // Personal task archives — per-user "hide from My Tasks" without changing
  // the task's global status (Leaders still see it as Completed in Task Queue).
  archivedTasks UserArchivedTask[] @relation("UserArchivedTasks")

  // Per-checklist-item claims (TEAM-type routine tasks)
  claimedChecklistItems ChecklistItem[] @relation("ChecklistItemAssignee")

  // Workspace custom emojis the user has created.
  customEmojis CustomEmoji[] @relation("CustomEmojiCreator")

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

// ==========================================
// AHA SMART TRACKER MODELS (Migrated from Supabase)
// ==========================================

model Team {
  id               String                @id @default(uuid())
  name             String                @db.VarChar(255)
  // Short handle for @team mentions in channels (e.g. 'tfbi', 'tpr'). Unique when set.
  mentionHandle    String?               @unique @map("mention_handle") @db.VarChar(20)
  createdAt        DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  users            User[]
  projects         Project[]
  routineTemplates RoutineTaskTemplate[] @relation("TeamRoutineTemplates")
  assignedTasks    Task[]                @relation("TeamAssignedTasks")
  ownedChannels    Channel[]             @relation("TeamOwnedChannels")

  @@map("teams")
}

model Project {
  id                String    @id @default(uuid())
  name              String    @db.VarChar(255)
  description       String?
  status            String    @default("active") // 'active', 'on-hold', 'completed', 'archived'
  deadline          DateTime? @db.Date
  color             String?   @default("#6366f1") @db.VarChar(7)
  teamId            String    @map("team_id")
  team              Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  googleSheetSyncId String?   @map("google_sheet_sync_id") @db.VarChar(255)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  tasks             Task[]

  @@map("projects")
}

model Task {
  id          String  @id @default(uuid())
  title       String  @db.VarChar(255)
  description String?
  status      String  @default("todo") // 'todo', 'in-progress', 'pending', 'review', 'done', 'pending_completion_details'
  priority    String  @default("medium") // 'low', 'medium', 'high'

  // Ticketing System Fields
  requesterName     String? @map("requester_name") @db.VarChar(255)
  requesterEmail    String? @map("requester_email") @db.VarChar(255)
  requesterDivision String? @map("requester_division") @db.VarChar(255)
  urgency           String? @db.VarChar(50) // 'P1', 'P2', 'P3', 'P4', '5-minute'
  attachments       Json    @default("[]")
  customFields      Json    @default("{}") @map("custom_fields")

  // Completion Workflow Fields
  difficultyScore Int?    @map("difficulty_score")
  feedbackNotes   String? @map("feedback_notes")

  // Request & Meeting Fields
  requestType        String? @map("request_type")
  attachmentLink     String? @map("attachment_link")
  impactDescription  String? @map("impact_description")
  relatedProjectName String? @map("related_project_name")
  meetingDateRange   String? @map("meeting_date_range")
  meetingDuration    String? @map("meeting_duration")
  meetingPurpose     String? @map("meeting_purpose")
  taskToken          String? @map("task_token")

  // Completion fields
  completedBy       String? @map("completed_by")
  completedByUser   User?   @relation("CompletedByTasks", fields: [completedBy], references: [id], onDelete: SetNull)
  actualTimeSpent   Float?  @map("actual_time_spent")
  timeUnit          String? @map("time_unit")
  resolutionSummary String? @map("resolution_summary")

  dueDate               DateTime? @map("due_date") @db.Timestamptz(6)
  projectId             String?   @map("project_id")
  project               Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assigneeId            String?   @map("assignee_id")
  assignee              User?     @relation("AssigneeTasks", fields: [assigneeId], references: [id], onDelete: SetNull)
  notes                 String?
  isRecurring           Boolean   @default(false) @map("is_recurring")
  recurrenceType        String?   @map("recurrence_type") @db.VarChar(20)
  // Carried from the RoutineTaskTemplate when the cron spawns a Task instance.
  // Null on non-routine tasks (queue/direct-request/etc.). Drives the card's
  // claim flow: INDIVIDUAL → "Claim Task" button locks the card; TEAM →
  // per-checklist-item claim, with overall progress from item completion.
  type                  TemplateType?        @map("template_type")
  routineTemplateId     String?              @map("routine_template_id")
  routineTemplate       RoutineTaskTemplate? @relation("TaskFromRoutineTemplate", fields: [routineTemplateId], references: [id], onDelete: SetNull)
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  claimedAt             DateTime? @map("claimed_at") @db.Timestamptz(6)
  completedAt           DateTime? @map("completed_at") @db.Timestamptz(6)
  // Set when the assignee dismisses the Team Inbox "Overdue" bucket for this
  // task (e.g. by dragging it back to In Progress). The card still has a
  // past dueDate; this just stops it from showing in the Overdue column.
  // Reset implicitly when dueDate is extended past now.
  overdueAcknowledgedAt DateTime? @map("overdue_acknowledged_at") @db.Timestamptz(6)

  // Conversation link (for DM-created tasks)
  conversationId String? @map("conversation_id")

  // Direct Request Fields
  source           String    @default("queue") @db.VarChar(30) // 'queue' | 'direct_request' | 'dm' | 'leader_created' | 'direct_assign'
  directAssigneeId String?   @map("direct_assignee_id")
  directAssignee   User?     @relation("DirectAssigneeTasks", fields: [directAssigneeId], references: [id], onDelete: SetNull)
  responseDeadline DateTime? @map("response_deadline") @db.Timestamptz(6)

  // Direct Assign Fields — tasks posted into a team channel for any member to claim
  targetChannelId  String?         @map("target_channel_id")
  targetChannel    Channel?        @relation("DirectAssignChannel", fields: [targetChannelId], references: [id], onDelete: SetNull)
  channelMessageId String?         @map("channel_message_id")
  // Cascade: when the source channel message is deleted (requester deletes
  // their own post, channel cleanup, etc.) the orphaned Task is removed too.
  // Previously SetNull, which left dead-end cards in the team inbox.
  channelMessage   ChannelMessage? @relation("DirectAssignMessage", fields: [channelMessageId], references: [id], onDelete: Cascade)
  // Which team this task is assigned to. Drives the per-team Inbox view.
  // Derived from the target channel's allowed-team rules at submission time.
  assignedTeamId   String?         @map("assigned_team_id")
  assignedTeam     Team?           @relation("TeamAssignedTasks", fields: [assignedTeamId], references: [id], onDelete: SetNull)

  // Collaboration — "Request to Help" feature
  needsHelp       Boolean   @default(false) @map("needs_help")
  helpRequestedAt DateTime? @map("help_requested_at") @db.Timestamptz(6)

  // Pending state — task is paused waiting on something external (a brand
  // price update, partner confirmation, internal approval, etc.). Tasks in
  // this state are excluded from the Overdue bucket so the assignee isn't
  // penalized for blockers outside their control. status moves to 'pending'
  // and is restored from `pendedFromStatus` when resumed.
  pendingReason    String?   @map("pending_reason")
  pendingTag       String?   @map("pending_tag") @db.VarChar(40) // 'waiting_on_brand' | 'waiting_on_partner' | 'waiting_on_internal' | 'waiting_on_user' | 'other'
  pendedAt         DateTime? @map("pended_at") @db.Timestamptz(6)
  pendedBy         String?   @map("pended_by")
  pendedFromStatus String?   @map("pended_from_status") @db.VarChar(40)

  reviews          TaskReview[]
  comments         TaskComment[]
  delegations      TaskDelegation[]
  savedBy          SavedTask[]
  collaborators    TaskCollaborator[]
  personalArchives UserArchivedTask[] @relation("TaskUserArchives")
  checklistItems   ChecklistItem[]

  @@map("tasks")
}

// Trello-style sub-tasks attached to a Task. position keeps a stable
// user-defined order; isCompleted drives the inbox card's progress bar
// + percentage. Cascade-deleted with the parent task.
model ChecklistItem {
  id          String   @id @default(uuid())
  taskId      String   @map("task_id")
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  title       String
  isCompleted Boolean  @default(false) @map("is_completed")
  position    Int      @default(0)
  // For TEAM-type Tasks the cron leaves items unassigned; users claim items
  // individually from the channel card. For INDIVIDUAL-type Tasks this stays
  // null — the whole-task assignee owns every item.
  assigneeId  String?  @map("assignee_id")
  assignee    User?    @relation("ChecklistItemAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  claimedAt   DateTime? @map("claimed_at") @db.Timestamptz(6)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([taskId])
  @@index([assigneeId])
  @@map("checklist_item")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   @db.VarChar(50) // 'task_assigned', 'task_updated', 'reminder', 'mention'
  title     String   @db.VarChar(255)
  message   String
  read      Boolean  @default(false)
  data      Json?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("notifications")
}

model Meeting {
  id            String         @id @default(uuid())
  title         String         @db.VarChar(255)
  description   String?
  meetingDate   String         @map("meeting_date") @db.VarChar(10) // YYYY-MM-DD
  startTime     String         @map("start_time") @db.VarChar(8) // HH:MM
  endTime       String         @map("end_time") @db.VarChar(8)
  createdBy     String         @map("created_by")
  creator       User           @relation("MeetingCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  assignedTo    String         @map("assigned_to")
  assignee      User           @relation("MeetingAssignee", fields: [assignedTo], references: [id], onDelete: Cascade)
  source        String         @default("member") @db.VarChar(50) // 'leader', 'member', 'partner_relations'
  status        String         @default("confirmed") @db.VarChar(50) // 'confirmed', 'pending', 'cancelled'
  notifyBefore  Int            @default(0) @map("notify_before")
  googleEventId String?        @map("google_event_id")
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  guests        MeetingGuest[]

  @@map("meetings")
}

model MeetingGuest {
  id        String   @id @default(uuid())
  meetingId String   @map("meeting_id")
  meeting   Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([meetingId, userId])
  @@map("meeting_guests")
}

model GoogleToken {
  id           String   @id @default(uuid())
  userId       String   @unique @map("user_id")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken  String   @map("access_token")
  refreshToken String   @map("refresh_token")
  expiryDate   BigInt?  @map("expiry_date")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("google_tokens")
}

// ==========================================
// TASK REVIEWS
// ==========================================

model TaskReview {
  id            String   @id @default(uuid())
  taskId        String   @map("task_id")
  task          Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  reviewerType  String   @map("reviewer_type") @db.VarChar(20) // 'requester' or 'completer'
  rating        Int // 1-5 stars
  comment       String?
  reviewerName  String?  @map("reviewer_name") @db.VarChar(255)
  reviewerEmail String?  @map("reviewer_email") @db.VarChar(255)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([taskId, reviewerType])
  @@map("task_reviews")
}

model TaskComment {
  id           String   @id @default(uuid())
  taskId       String   @map("task_id")
  task         Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorUserId String?  @map("author_user_id")
  authorUser   User?    @relation(fields: [authorUserId], references: [id])
  authorName   String   @map("author_name") @db.VarChar(255)
  authorEmail  String?  @map("author_email") @db.VarChar(255)
  message      String
  attachments  Json     @default("[]")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Phase-2 mirror: when this comment is the canonical record on the task
  // side of a Direct Assign card sync, mirrorReplyId points to the matching
  // ThreadReply on the source channel message. SetNull on delete so we never
  // leave a dangling reference if the channel-side reply is deleted first.
  mirrorReplyId String?      @unique @map("mirror_reply_id")
  mirrorReply   ThreadReply? @relation("CommentReplyMirror", fields: [mirrorReplyId], references: [id], onDelete: SetNull)

  reactions MessageReaction[] @relation("TaskCommentReactions")

  @@index([taskId, createdAt])
  @@map("task_comments")
}

// ==========================================
// TASK DELEGATIONS (Direct Request)
// ==========================================

model TaskDelegation {
  id         String   @id @default(uuid())
  taskId     String   @map("task_id")
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  fromUserId String   @map("from_user_id")
  fromUser   User     @relation("TaskDelegationFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUserId   String   @map("to_user_id")
  toUser     User     @relation("TaskDelegationTo", fields: [toUserId], references: [id], onDelete: Cascade)
  reason     String?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("task_delegations")
}

// ==========================================
// CHAT / DIRECT MESSAGES
// ==========================================

model Conversation {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  participants ConversationParticipant[]
  messages     DirectMessage[]

  @@map("conversations")
}

model ConversationParticipant {
  id             String       @id @default(uuid())
  conversationId String       @map("conversation_id")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String       @map("user_id")
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastReadAt     DateTime?    @map("last_read_at") @db.Timestamptz(6)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([conversationId, userId])
  @@map("conversation_participants")
}

model DirectMessage {
  id             String       @id @default(uuid())
  conversationId String       @map("conversation_id")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String       @map("sender_id")
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  content        String
  attachments    Json         @default("[]")
  type           String       @default("text") @db.VarChar(30) // 'text' | 'task_card' | 'status_update'
  taskId         String?      @map("task_id")
  taskSnapshot   Json?        @map("task_snapshot")
  isEdited       Boolean      @default(false) @map("is_edited")
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)

  reactions DmReaction[]

  @@index([conversationId, createdAt])
  @@map("direct_messages")
}

model DmReaction {
  id        String        @id @default(uuid())
  emoji     String        @db.VarChar(32)
  userId    String        @map("user_id")
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messageId String        @map("message_id")
  message   DirectMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([userId, emoji, messageId])
  @@map("dm_reactions")
}

// ==========================================
// THREADED COMMENT CHANNELS
// ==========================================

model Channel {
  id                String   @id @default(uuid())
  name              String   @db.VarChar(100)
  description       String?
  createdBy         String   @map("created_by")
  creator           User     @relation("ChannelCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  isPrivate         Boolean  @default(false) @map("is_private")
  isArchived        Boolean  @default(false) @map("is_archived")
  allowedTeamIds    String[] @default([]) @map("allowed_team_ids")
  visibleToAllTeams Boolean  @default(false) @map("visible_to_all_teams")
  // Owning team for assign_task channels — every direct-assigned task posted in
  // this channel inherits this team as task.assignedTeamId. Required at the API
  // layer when purpose === 'assign_task'; optional for discussion channels.
  teamId            String?  @map("team_id")
  team              Team?    @relation("TeamOwnedChannels", fields: [teamId], references: [id], onDelete: SetNull)
  // 'discussion' for team forums, 'assign_task' for channels used by Direct Assign.
  purpose           String   @default("discussion") @map("purpose") @db.VarChar(20)
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  messages          ChannelMessage[]
  readStatuses      ChannelReadStatus[]
  members           ChannelMember[]
  directAssignTasks Task[]              @relation("DirectAssignChannel")
  routineTemplates  RoutineTaskTemplate[] @relation("RoutineTemplateChannel")

  @@map("channels")
}

model ChannelMember {
  id        String   @id @default(uuid())
  channelId String   @map("channel_id")
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([channelId, userId])
  @@map("channel_members")
}

model ChannelMessage {
  id          String   @id @default(uuid())
  channelId   String   @map("channel_id")
  channel     Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  senderId    String   @map("sender_id")
  sender      User     @relation("ChannelMessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  content     String
  attachments Json     @default("[]")
  mentions    Json     @default("[]")
  replyCount  Int      @default(0) @map("reply_count")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  replies           ThreadReply[]
  reactions         MessageReaction[] @relation("MessageReactions")
  savedBy           SavedMessage[]
  directAssignTasks Task[]            @relation("DirectAssignMessage")

  @@index([channelId, createdAt])
  @@map("channel_messages")
}

model ThreadReply {
  id          String         @id @default(uuid())
  messageId   String         @map("message_id")
  message     ChannelMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  senderId    String         @map("sender_id")
  sender      User           @relation("ThreadReplySender", fields: [senderId], references: [id], onDelete: Cascade)
  content     String
  attachments Json           @default("[]")
  mentions    Json           @default("[]")
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  reactions MessageReaction[] @relation("ReplyReactions")
  savedBy   SavedMessage[]

  // Phase-2 mirror reverse-side: the TaskComment that mirrors this reply,
  // when the parent ChannelMessage is a Direct Assign card. The FK lives on
  // TaskComment.mirrorReplyId — this is the back-reference so we can join
  // either direction in queries.
  mirrorComment TaskComment? @relation("CommentReplyMirror")

  @@index([messageId, createdAt])
  @@map("thread_replies")
}

model MessageReaction {
  id            String          @id @default(uuid())
  emoji         String          @db.VarChar(32)
  userId        String          @map("user_id")
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  messageId     String?         @map("message_id")
  message       ChannelMessage? @relation("MessageReactions", fields: [messageId], references: [id], onDelete: Cascade)
  replyId       String?         @map("reply_id")
  reply         ThreadReply?    @relation("ReplyReactions", fields: [replyId], references: [id], onDelete: Cascade)
  // Phase-2: reactions can also live on a TaskComment so the modal-side
  // reaction picker has somewhere to write. Mirror logic in
  // lib/syncCommentReply ensures comment <-> reply reactions stay in sync.
  taskCommentId String?         @map("task_comment_id")
  taskComment   TaskComment?    @relation("TaskCommentReactions", fields: [taskCommentId], references: [id], onDelete: Cascade)
  createdAt     DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([userId, emoji, messageId])
  @@unique([userId, emoji, replyId])
  @@unique([userId, emoji, taskCommentId])
  @@map("message_reactions")
}

model SavedMessage {
  id        String         @id @default(uuid())
  userId    String         @map("user_id")
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  messageId String         @map("message_id")
  message   ChannelMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  replyId   String?        @map("reply_id")
  reply     ThreadReply?   @relation(fields: [replyId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([userId, messageId, replyId])
  @@map("saved_messages")
}

model SavedTask {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskId    String   @map("task_id")
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([userId, taskId])
  @@index([userId, createdAt])
  @@map("saved_tasks")
}

// Option 1 "Request to Help" — junction between a task and users helping with it.
// The original assignee remains on Task.assigneeId; helpers are additional collaborators.
model TaskCollaborator {
  id          String    @id @default(uuid())
  taskId      String    @map("task_id")
  task        Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId      String    @map("user_id")
  user        User      @relation("TaskHelpers", fields: [userId], references: [id], onDelete: Cascade)
  role        String    @default("helper") @db.VarChar(20) // 'helper' (owner stays on Task.assigneeId)
  status      String    @default("pending") @db.VarChar(20) // 'pending' → 'approved' (deny = delete row)
  requestedAt DateTime  @default(now()) @map("requested_at") @db.Timestamptz(6)
  joinedAt    DateTime? @map("joined_at") @db.Timestamptz(6) // set when status flips to 'approved'

  @@unique([taskId, userId])
  @@index([taskId])
  @@index([userId, requestedAt])
  @@map("task_collaborators")
}

model ChannelReadStatus {
  id         String   @id @default(uuid())
  channelId  String   @map("channel_id")
  channel    Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastReadAt DateTime @default(now()) @map("last_read_at") @db.Timestamptz(6)

  @@unique([channelId, userId])
  @@map("channel_read_status")
}

// ==========================================
// NOTES (Google Keep-style)
// ==========================================

model Note {
  id        String   @id @default(uuid())
  title     String   @default("") @db.VarChar(500)
  content   String   @default("")
  color     String   @default("default") @db.VarChar(20) // 'default','yellow','green','blue','purple','pink','red','orange'
  pinned    Boolean  @default(false)
  archived  Boolean  @default(false)
  userId    String   @map("user_id")
  user      User     @relation("UserNotes", fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("notes")
}

// ==========================================
// AHA ORBIT - ROUTINE TASK MANAGEMENT
// ==========================================

// Drives how generated Task instances are claimed.
//   INDIVIDUAL — one user claims the whole Task; the card locks to them.
//   TEAM       — checklist items are claimed individually; the Task auto-
//                completes when every item is done.
// Default INDIVIDUAL keeps existing rows unchanged on migration.
enum TemplateType {
  INDIVIDUAL
  TEAM

  @@map("template_type")
}

model RoutineTaskTemplate {
  id           String       @id @default(uuid())
  name         String       @db.VarChar(255)
  description  String?
  frequency    String       @db.VarChar(20) // 'daily', 'weekly', 'monthly'
  category     String?      @db.VarChar(100)
  // INDIVIDUAL vs TEAM. The legacy `isTeamWide` flag is kept for back-compat
  // with existing rows/queries; new code should read `type`.
  type         TemplateType @default(INDIVIDUAL)
  deadlineTime String?      @map("deadline_time") @db.VarChar(5) // HH:MM format, e.g. "17:00"
  deadlineDay  Int?         @map("deadline_day") // For weekly: 1=Mon..7=Sun, for monthly: 1-31
  // Channel the bot posts the generated Task card into. Null = no channel
  // (template still appears on /orbit but the bot won't post a reminder).
  channelId    String?      @map("channel_id")
  channel      Channel?     @relation("RoutineTemplateChannel", fields: [channelId], references: [id], onDelete: SetNull)
  teamId       String?      @map("team_id")
  team         Team?        @relation("TeamRoutineTemplates", fields: [teamId], references: [id], onDelete: SetNull)
  teamIds      Json         @default("[]") @map("team_ids") // Array of team IDs for multi-team visibility
  isTeamWide   Boolean      @default(false) @map("is_team_wide") // DEPRECATED — superseded by `type`. Kept so existing reads don't break.
  isActive     Boolean      @default(true) @map("is_active")
  createdBy    String       @map("created_by")
  creator      User         @relation("RoutineTemplateCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  claims         RoutineTaskClaim[]
  checklistItems TemplateChecklistItem[]
  spawnedTasks   Task[]                  @relation("TaskFromRoutineTemplate")

  @@map("routine_task_templates")
}

// Per-template claimable items used when the template's type is TEAM. The
// cron job copies these into the spawned Task's ChecklistItem rows so the
// generated card has the same line items every period.
model TemplateChecklistItem {
  id         String              @id @default(uuid())
  templateId String              @map("template_id")
  template   RoutineTaskTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  title      String
  position   Int                 @default(0)
  createdAt  DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([templateId])
  @@map("template_checklist_items")
}

model RoutineTaskClaim {
  id             String              @id @default(uuid())
  templateId     String              @map("template_id")
  template       RoutineTaskTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  claimedBy      String              @map("claimed_by")
  claimer        User                @relation("RoutineClaimUser", fields: [claimedBy], references: [id], onDelete: Cascade)
  period         String              @db.VarChar(20)
  status         String              @default("claimed") @db.VarChar(20)
  completedAt    DateTime?           @map("completed_at") @db.Timestamptz(6)
  completionNote String?             @map("completion_note")
  attachments    Json                @default("[]") // Image URLs / file attachments for proof of work
  createdAt      DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)

  delegations RoutineTaskDelegation[]

  @@unique([templateId, period, claimedBy])
  @@map("routine_task_claims")
}

model RoutineTaskDelegation {
  id         String           @id @default(uuid())
  claimId    String           @map("claim_id")
  claim      RoutineTaskClaim @relation(fields: [claimId], references: [id], onDelete: Cascade)
  fromUserId String           @map("from_user_id")
  fromUser   User             @relation("DelegationFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUserId   String           @map("to_user_id")
  toUser     User             @relation("DelegationTo", fields: [toUserId], references: [id], onDelete: Cascade)
  status     String           @default("pending") @db.VarChar(20)
  createdAt  DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("routine_task_delegations")
}

// ==========================================
// ACCOUNT ACTIVATION
// ==========================================

model ActivationToken {
  id        String   @id @default(uuid())
  email     String
  name      String
  token     String   @unique
  expiresAt DateTime @map("expires_at") @db.Timestamptz(6)
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("activation_tokens")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  expiresAt DateTime @map("expires_at") @db.Timestamptz(6)
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("password_reset_tokens")
}

// ==========================================
// ACTIVITY LOG
// ==========================================

model ActivityLog {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action      String   @db.VarChar(50) // 'task_claimed', 'task_completed', 'status_changed', 'channel_message', 'orbit_claimed', etc.
  description String
  entityType  String?  @map("entity_type") @db.VarChar(50) // 'task', 'channel', 'orbit', 'user'
  entityId    String?  @map("entity_id")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([createdAt])
  @@index([userId])
  @@map("activity_logs")
}

model ChangelogEntry {
  id          String   @id @default(uuid())
  version     String?
  title       String
  summary     String   @db.Text
  category    String   @default("feature") @db.VarChar(20) // 'feature' | 'improvement' | 'fix' | 'breaking'
  pinned      Boolean  @default(false)
  publishedAt DateTime @default(now()) @map("published_at") @db.Timestamptz(6)
  createdBy   String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([publishedAt])
  @@map("changelog_entries")
}

model Milestone {
  id          String   @id @default(uuid())
  type        String   @db.VarChar(20) // 'recurring' | 'first'
  threshold   Int
  rewardLabel String   @map("reward_label") @db.VarChar(255)
  description String?  @db.Text
  emoji       String?  @db.VarChar(10)
  active      Boolean  @default(true)
  createdById String   @map("created_by_id")
  createdBy   User     @relation("MilestonesCreated", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  // First-to-reach: locked to the first claimer
  claimedById   String?   @map("claimed_by_id")
  claimedByUser User?     @relation("MilestonesClaimed", fields: [claimedById], references: [id], onDelete: SetNull)
  claimedAt     DateTime? @map("claimed_at") @db.Timestamptz(6)

  @@map("milestones")
}

// Per-day active-seconds snapshots — populated by /api/heartbeat. Lets us
// compute "This Week" / "This Month" totals without losing data on the daily
// reset of User.activeSecondsToday.
model UserActivityDaily {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  user          User     @relation("UserActivityDailies", fields: [userId], references: [id], onDelete: Cascade)
  date          DateTime @db.Date
  activeSeconds Int      @default(0) @map("active_seconds")

  @@unique([userId, date])
  @@index([date])
  @@map("user_activity_daily")
}

// Per-user "personal archive" of completed tasks. Allows a member to clear a
// completed task from their My Tasks view without flipping the task's global
// status. The Task Queue (Leader view) continues to show the task as Completed
// until a Leader explicitly archives it through PUT /api/tasks/[id]/archive.
model UserArchivedTask {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  user       User     @relation("UserArchivedTasks", fields: [userId], references: [id], onDelete: Cascade)
  taskId     String   @map("task_id")
  task       Task     @relation("TaskUserArchives", fields: [taskId], references: [id], onDelete: Cascade)
  archivedAt DateTime @default(now()) @map("archived_at") @db.Timestamptz(6)

  @@unique([userId, taskId])
  @@index([userId])
  @@map("user_archived_tasks")
}

// Workspace-wide custom emojis. Slack-style: one image + one shortcode name,
// rendered inline in messages where `:name:` appears, and selectable from the
// emoji picker's "Custom" tab. Names are lowercase, alphanumeric with `-`/`_`,
// and globally unique within the workspace. Image bytes live wherever the
// existing /api/upload route stores them — we just hold the URL.
model CustomEmoji {
  id        String   @id @default(uuid())
  name      String   @unique // shortcode without surrounding colons, e.g. "party-parrot"
  imageUrl  String   @map("image_url")
  creatorId String   @map("creator_id")
  creator   User     @relation("CustomEmojiCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([creatorId])
  @@map("custom_emoji")
}
